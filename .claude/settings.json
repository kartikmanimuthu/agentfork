{
  "permissions": {
    "allow": [
      "Bash(bun install)",
      "Bash(bun run *)",
      "Bash(bunx vitest *)",
      "Bash(bunx playwright *)",
      "Bash(bunx prisma generate *)",
      "Bash(bunx prisma db push *)",
      "Bash(bunx prisma migrate *)",
      "Bash(bunx prisma format *)",
      "Bash(nx *)",
      "Bash(docker compose *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(which *)",
      "Bash(echo *)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "If the file path matches `.env` (but NOT `.env.example`, `.env.local`, etc.), STOP and ask for explicit confirmation. Explain that .env files may contain secrets."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "If the file ends with .ts, .tsx, .js, .jsx, .css, or .json, run `bunx prettier --write <file>`. If prettier fails, just continue."
          },
          {
            "type": "prompt",
            "prompt": "If the file ends with .ts or .tsx and is inside apps/ or libs/, run `bunx tsc --noEmit` to type-check. Only report errors."
          }
        ]
      }
    ]
  }
}
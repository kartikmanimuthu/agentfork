# ============================================================================
# Database
# ============================================================================
# Local dev: docker compose up -d  (starts postgres with pgvector)
DATABASE_URL="postgresql://chatbot_admin:chatbot_dev@localhost:5432/chatbot?schema=public"

# ============================================================================
# NextAuth
# ============================================================================
NEXTAUTH_URL=http://localhost:3001
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# ============================================================================
# AWS
# ============================================================================
AWS_REGION=ap-south-1

# Explicit credentials (optional if using AWS CLI profile or IAM role)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=your-session-token  # only for temporary credentials

# ============================================================================
# AWS Cognito — SSO login (optional)
# Credentials-based login works without these.
# To enable SSO: create a Cognito User Pool + App Client, then fill in below.
# Callback URL to set in Cognito: http://localhost:3001/api/auth/callback/cognito
# ============================================================================
# COGNITO_USER_POOL_ID=ap-south-1_example
# COGNITO_APP_CLIENT_ID=your-app-client-id
# COGNITO_APP_CLIENT_SECRET=your-app-client-secret
# COGNITO_ISSUER=https://cognito-idp.ap-south-1.amazonaws.com/ap-south-1_example

# ============================================================================
# AWS Bedrock — AI models
# ============================================================================
# Default chat model (Claude Sonnet via Bedrock)
BEDROCK_CHAT_MODEL=anthropic.claude-sonnet-4-20250514
# Embedding model for RAG pipeline
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ============================================================================
# Application
# ============================================================================
NODE_ENV=development

{
  "name": "web-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web-ui",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/web-ui/.next"],
      "options": {
        "command": "bun run build",
        "cwd": "apps/web-ui"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "bun run dev",
        "cwd": "apps/web-ui"
      }
    }
  }
}

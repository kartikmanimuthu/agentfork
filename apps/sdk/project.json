{
  "name": "sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/sdk/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "bunx stencil build",
        "cwd": "apps/sdk"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "bunx stencil build --dev --watch --serve --port 3000",
        "cwd": "apps/sdk"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx stencil test --spec",
        "cwd": "apps/sdk"
      }
    }
  }
}

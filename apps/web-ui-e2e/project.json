{
  "name": "web-ui-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["web-ui"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "bunx playwright test",
        "cwd": "apps/web-ui-e2e"
      }
    },
    "e2e:ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx playwright test --ui",
        "cwd": "apps/web-ui-e2e"
      }
    }
  }
}

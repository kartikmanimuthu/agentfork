    "e2e:api": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": [],
      "options": {
        "command": "bunx playwright test --grep @inference-api",
        "cwd": "apps/web-ui-e2e"
      }
    },
    "e2e:smoke": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": [],
      "options": {
        "command": "bunx playwright test --grep @smoke",
        "cwd": "apps/web-ui-e2e"
      }
    },
    "e2e:regression": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": [],
      "options": {
        "command": "bunx playwright test --grep @regression",
        "cwd": "apps/web-ui-e2e"
      }
    }

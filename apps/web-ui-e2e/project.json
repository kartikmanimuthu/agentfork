        "cwd": "apps/web-ui-e2e"
      }
    },
    "e2e:docs": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": [],
      "options": {
        "command": "bunx playwright test --grep @docs",
        "cwd": "apps/web-ui-e2e"
      }
    },
    "e2e:navigation": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": [],
      "options": {
        "command": "bunx playwright test --grep @navigation",
        "cwd": "apps/web-ui-e2e"
      }

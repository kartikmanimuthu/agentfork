# ============================================================================
# Database
# ============================================================================
# Local dev: docker compose up -d  (starts postgres with pgvector)
DATABASE_URL="postgresql://chatbot_admin:chatbot_dev@localhost:5432/chatbot?schema=public"

# ============================================================================
# AWS
# ============================================================================
AWS_REGION=ap-south-1

# Explicit credentials (optional if using AWS CLI profile or IAM role)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ============================================================================
# Worker configuration
# ============================================================================
# Execution architecture: "vertical" (single process) or "horizontal" (multi-process)
WORKER_ARCH=vertical
NODE_ENV=development

# ============================================================================
# AWS ECS — only needed for ECS-based horizontal scaling (optional)
# ============================================================================
# ECS_CLUSTER_ARN=arn:aws:ecs:ap-south-1:123456789012:cluster/chatbot
# WORKER_TASK_DEFINITION_ARN=arn:aws:ecs:ap-south-1:123456789012:task-definition/chatbot-workers
# PRIVATE_SUBNET_IDS=subnet-xxx,subnet-yyy
# SECURITY_GROUP_IDS=sg-xxx

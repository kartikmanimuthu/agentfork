{
  "name": "infra",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "infra",
  "projectType": "application",
  "targets": {
    "deploy-networking": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd infra/networking && npm install && pulumi up --yes --stack prod",
        "cwd": "."
      }
    },
    "deploy-compute": {
      "executor": "nx:run-commands",
      "dependsOn": ["deploy-networking"],
      "options": {
        "command": "cd infra/compute && npm install && PULUMI_CONFIG_PASSPHRASE=\"\" pulumi up --yes --stack prod",
        "cwd": "."
      }
    },
    "preview-networking": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd infra/networking && pulumi preview --stack prod",
        "cwd": "."
      }
    },
    "preview-compute": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd infra/compute && PULUMI_CONFIG_PASSPHRASE=\"\" pulumi preview --stack prod",
        "cwd": "."
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd infra/networking && pulumi preview --stack prod && cd ../compute && PULUMI_CONFIG_PASSPHRASE=\"\" pulumi preview --stack prod",
        "cwd": "."
      }
    },
    "deploy-cicd": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd infra/cicd && npm install && pulumi up --yes --stack prod",
        "cwd": "."
      }
    },
    "preview-cicd": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd infra/cicd && pulumi preview --stack prod",
        "cwd": "."
      }
    }
  }
}

{
  "name": "@chatbot/source",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.2.12",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "infra"
  ],
  "scripts": {
    "setup": "[ -f .env ] || cp .env.example .env && bun run prepare && bunx prisma migrate deploy --schema=./prisma/schema.prisma",
    "prepare": "prisma generate --schema=./prisma/schema.prisma",
    "dev": "nx serve web-ui",
    "dev:workers": "nx serve workers",
    "dev:all": "nx run-many -t serve -p web-ui,workers --parallel",
    "build": "nx run-many -t build --all",
    "build:web": "nx build web-ui",
    "build:workers": "nx build workers",
    "test": "nx run-many -t test -p shared,ai,workers",
    "test:workers": "nx test workers",
    "test:shared": "nx test shared",
    "test:ai": "nx test ai",
    "e2e": "nx e2e web-ui",
    "e2e:ui": "nx e2e:ui web-ui",
    "affected:test": "nx affected -t test",
    "affected:build": "nx affected -t build",
    "graph": "nx graph"
  },
  "devDependencies": {
    "@nx/eslint-plugin": "^21.0.0",
    "@nx/js": "^21.0.0",
    "@nx/next": "^21.0.0",
    "@nx/vite": "^21.0.0",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "nx": "^21.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.0",
    "prisma": "^6.0.0",
    "shadcn": "^4.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.100",
    "@ai-sdk/react": "^3.0.176",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-cognito-identity-provider": "^3.670.0",
    "@aws-sdk/client-ecs": "^3.1041.0",
    "@prisma/client": "^6.0.0",
    "@t3-oss/env-core": "^0.13.11",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.0.0",
    "ai": "^6.0.174",
    "bcryptjs": "^3.0.3",
    "next-auth": "^4.24.14",
    "pino": "^9.0.0",
    "tslib": "^2.8.0",
    "zod": "^4.4.0",
    "zustand": "^5.0.0"
  }
}

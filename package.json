{
  "name": "@chatbot/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "bun@1.2.12",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "infra"
  ],
  "scripts": {
    "setup": "[ -f .env ] || cp .env.example .env && bun run prepare && bunx prisma migrate deploy --schema=./prisma/schema.prisma",
    "prepare": "prisma generate --schema=./prisma/schema.prisma",
    "dev": "nx serve web-ui",
    "dev:workers": "nx serve workers",
    "dev:all": "SDK_DEV=true nx run-many -t serve -p web-ui,workers,sdk --parallel",
    "build": "nx run-many -t build --all",
    "build:web": "nx build web-ui",
    "build:workers": "nx build workers",
    "test": "nx run-many -t test -p shared,ai,workers",
    "test:workers": "nx test workers",
    "test:shared": "nx test shared",
    "test:ai": "nx test ai",
    "e2e": "nx e2e web-ui-e2e",
    "e2e:dev": "nx e2e:dev web-ui-e2e",
    "e2e:ui": "nx e2e:ui web-ui-e2e",
    "e2e:codegen": "nx codegen web-ui-e2e",
    "e2e:auth": "nx e2e:auth web-ui-e2e",
    "e2e:sso": "nx e2e:sso web-ui-e2e",
    "e2e:marketing": "nx e2e:marketing web-ui-e2e",
    "e2e:docs": "nx e2e:docs web-ui-e2e",
    "e2e:navigation": "nx e2e:navigation web-ui-e2e",
    "e2e:api": "nx e2e:api web-ui-e2e",
    "e2e:smoke": "nx e2e:smoke web-ui-e2e",
    "e2e:regression": "nx e2e:regression web-ui-e2e",
    "affected:test": "nx affected -t test",
    "affected:build": "nx affected -t build",
    "graph": "nx graph",
    "sdk:build": "cd apps/sdk && bunx stencil build && rm -rf ../web-ui/public/sdk-assets && mkdir -p ../web-ui/public/sdk-assets && cp dist/smc-chat-widget/*.js ../web-ui/public/sdk-assets/",
    "sdk:dev": "cd apps/sdk && bunx stencil build --dev --watch --serve --port 3007"
  },
  "devDependencies": {
    "@nx/eslint-plugin": "^21.0.0",
    "@nx/js": "^21.0.0",
    "@nx/next": "^21.0.0",
    "@nx/vite": "^21.0.0",
    "@playwright/test": "^1.59.1",
    "@stencil/vitest": "^1.12.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.5",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "jest-environment-jsdom": "29",
    "next": "^15.2.0",
    "nx": "^21.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.0",
    "prisma": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.117",
    "@ai-sdk/cohere": "^3.0.33",
    "@ai-sdk/openai": "^3.0.59",
    "@ai-sdk/react": "^3.0.176",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-bedrock": "^3.670.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.670.0",
    "@aws-sdk/client-ecs": "^3.1041.0",
    "@aws-sdk/client-s3": "^3.1042.0",
    "@aws-sdk/client-ses": "^3.670.0",
    "@aws-sdk/credential-provider-ini": "^3.972.38",
    "@aws-sdk/credential-provider-node": "^3.972.39",
    "@aws-sdk/s3-request-presigner": "^3.1042.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^6.0.0",
    "@t3-oss/env-core": "^0.13.11",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.0.0",
    "@xyflow/react": "^12.0.0",
    "ai": "^6.0.174",
    "bcryptjs": "^3.0.3",
    "crawlee": "^3.13.0",
    "jsdom": "^26.0.0",
    "mammoth": "^1.12.0",
    "next-auth": "^4.24.14",
    "pdf-parse": "1.1.1",
    "pino": "^9.0.0",
    "playwright": "^1.59.1",
    "puppeteer": "^25.1.0",
    "tslib": "^2.8.0",
    "turndown": "^7.2.0",
    "umap-js": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.0",
    "zustand": "^5.0.0"
  }
}
